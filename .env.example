# === Titan Gym Management SaaS - Environment Variables Example ===

# Supabase Connection (Required for Core App)
# Get these from Settings -> API in your Supabase dashboard
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-project-anon-key-here

# Gemini API Key (Optional: For AI Dashboards)
# Set your Gemini API key from AI Studio
GEMINI_API_KEY=your-gemini-key-here

# Local Server Config
# The URL for the local SQLite Express server
APP_URL=http://localhost:3000
PORT=3000

# Security Tip: Never commit your actual .env file to GitHub.
# Use this template to create a local .env file.
