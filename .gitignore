# === Professional .gitignore for React + Vite + Node + SQLite ===

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build Outputs
dist/
dist-ssr/
build/
out/
.next/

# Environment / Secrets (CRITICAL)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
*.cert

# Database (CRITICAL - Prevent leaking live user data)
sqlite.db
sqlite.db-journal
sqlite.db-shm
sqlite.db-wal
*.db
*.sqlite

# IDEs / Editors
.vscode/
.idea/
*.swp
*.swo
.project
.settings/
.classpath

# OS Generated
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
desktop.ini

# Testing
coverage/

# Logs
*.log
logs/

# Optional: AI Metadata
metadata.json
# (Only keep if required by AI Studio runtime)
